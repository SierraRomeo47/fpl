# Copy to `.env.local` (development) or `.env.production` on the server.
# Never commit files that contain real API keys.

NODE_ENV=development

# App URL (browser-visible where used)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: base URL for server-side fetches (e.g. dashboard AI page)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

PORT=3000

# --- Optional integrations (server-only preferred) ---

# Optional: NewsAPI.org — supplements RSS headlines when set (server-only; avoid
# NEXT_PUBLIC_NEWS_API_KEY so the key is not bundled for the client).
# Free tier: ~100 requests / 24h; dev reloads burn quota quickly.
# Without a key, /api/news/feed still serves BBC Sport + Guardian football RSS (parsed on the server).
NEWS_API_KEY=

# football-data.org
FOOTBALL_DATA_API_KEY=

# TheSportsDB (some routes still reference a placeholder if unset)
SPORTSDB_API_KEY=

# Understat / enriched player routes (season year, e.g. 2024)
UNDERSTAT_SEASON=
