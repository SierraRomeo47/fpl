'use client';

import { useEffect, useState } from 'react';
import { redirect } from 'next/navigation';
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { TrendingUp, TrendingDown, Trophy, ArrowRight, ChevronLeft, ChevronRight } from "lucide-react";
import { useFPLData, useEventPicks } from "@/lib/hooks/use-fpl-data";

// ============ UTILITY FUNCTIONS (Module Level) ============
function getPlayerPhotoUrl(player: any): string[] {
    return [
        `https://resources.premierleague.com/premierleague/photos/players/250x250/p${player.code}.png`,
        `https://resources.premierleague.com/premierleague/photos/players/250x250/p${player.photo}.png`,
        `https://resources.premierleague.com/premierleague/photos/players/250x250/p${player.id}.png`,
    ];
}

function getJerseyNumber(player: any): string | number {
    if (player.squad_number && player.squad_number > 0) return player.squad_number;
    const defaults: Record<number, number> = { 1: 1, 2: 5, 3: 8, 4: 9 };
    return defaults[player.element_type] || '?';
}
// ============ END UTILITY FUNCTIONS ============

export default function HistoryPage() {
    const [sessionData, setSessionData] = useState<{ entryId: number } | null>(null);
    const [selectedGW, setSelectedGW] = useState<number | null>(null);

    useEffect(() => {
        fetch('/api/session/create')
            .then(res => res.ok ? res.json() : Promise.reject())
            .then(data => setSessionData(data))
            .catch(() => redirect('/login'));
    }, []);

    const { bootstrap, history, isLoading } = useFPLData(sessionData?.entryId, selectedGW || undefined);
    const { data: picksData } = useEventPicks(sessionData?.entryId, selectedGW || undefined);

    useEffect(() => {
        if (history && !selectedGW) {
            // Default to most recent GW
            const lastGW = history.current[history.current.length - 1];
            setSelectedGW(lastGW?.event);
        }
    }, [history, selectedGW]);

    if (!sessionData || isLoading || !bootstrap || !history) {
        return (
            <div className="min-h-screen flex items-center justify-center">
                <div className="w-16 h-16 border-4 border-primary border-t-transparent rounded-full animate-spin" />
            </div>
        );
    }

    const teams = bootstrap.teams;
    const elements = bootstrap.elements;
    const getPlayer = (elementId: number) => elements.find((p: any) => p.id === elementId);
    const getTeam = (teamId: number) => teams.find((t: any) => t.id === teamId);

    const selectedGWData = history.current.find((gw: any) => gw.event === selectedGW);
    const prevGWData = history.current.find((gw: any) => gw.event === selectedGW! - 1);

    const PlayerMiniCard = ({ elementId, isCap, isVC }: { elementId: number, isCap?: boolean, isVC?: boolean }) => {
        const player = getPlayer(elementId);
        const team = getTeam(player?.team);
        if (!player) return null;

        const jerseyNumber = getJerseyNumber(player);
        const playerPhotoUrls = getPlayerPhotoUrl(player);

        return (
            <div className="relative bg-gradient-to-br from-card to-card/50 rounded-xl p-3 border border-primary/20 hover:border-primary/40 transition-all group">
                {isCap && <div className="absolute -top-2 -right-2 w-6 h-6 bg-yellow-500 rounded-full flex items-center justify-center text-xs font-bold z-10">C</div>}
                {isVC && <div className="absolute -top-2 -right-2 w-6 h-6 bg-gray-400 rounded-full flex items-center justify-center text-xs font-bold z-10">V</div>}

                <div className="flex items-center gap-2">
                    <div className="w-10 h-10 rounded-full overflow-hidden border-2 border-primary/30 bg-gradient-to-br from-primary/10 to-purple-500/10 flex-shrink-0">
                        <img
                            src={playerPhotoUrls[0]}
                            alt={player.web_name}
                            className="w-full h-full object-cover"
                            onError={(e) => {
                                const img = e.currentTarget;
                                const currentIndex = playerPhotoUrls.findIndex(url => img.src === url);
                                if (currentIndex < playerPhotoUrls.length - 1) {
                                    img.src = playerPhotoUrls[currentIndex + 1];
                                } else {
                                    img.style.display = 'none';
                                    const div = document.createElement('div');
                                    div.className = 'w-full h-full flex items-center justify-center text-sm font-bold text-primary';
                                    div.textContent = player.web_name[0];
                                    img.parentElement!.appendChild(div);
                                }
                            }}
                        />
                    </div>
                    <div className="flex-1 min-w-0">
                        <p className="font-bold text-sm truncate">{player.web_name}</p>
                        <p className="text-xs text-muted-foreground">{team?.short_name} • #{jerseyNumber}</p>
                    </div>
                    <div className="text-right">
                        <p className="text-lg font-black text-primary">{player.event_points || 0}</p>
                        <p className="text-xs text-muted-foreground">pts</p>
                    </div>
                </div>
            </div>
        );
    };

    return (
        <div className="min-h-screen bg-gradient-to-br from-background via-background to-primary/5 pb-24">
            <div className="max-w-7xl mx-auto p-4 md:p-6 space-y-6">
                {/* Header */}
                <div>
                    <h1 className="text-3xl font-bold">Season History</h1>
                    <p className="text-muted-foreground">View your gameweek performance and lineups</p>
                </div>

                {/* Gameweek Timeline */}
                <Card className="border-primary/20">
                    <CardHeader>
                        <CardTitle>Gameweek Timeline</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <div className="relative">
                            <div className="flex gap-2 overflow-x-auto pb-4 scrollbar-thin">
                                {history.current.map((gw: any) => {
                                    const isSelected = gw.event === selectedGW;
                                    const rankChange = history.current.find((g: any) => g.event === gw.event - 1)?.overall_rank
                                        ? history.current.find((g: any) => g.event === gw.event - 1)!.overall_rank - gw.overall_rank
                                        : 0;

                                    return (
                                        <button
                                            key={gw.event}
                                            onClick={() => setSelectedGW(gw.event)}
                                            className={`flex-shrink-0 w-32 p-4 rounded-xl border-2 transition-all ${isSelected
                                                ? 'border-primary bg-primary/10 scale-105'
                                                : 'border-border hover:border-primary/50 hover:bg-secondary/50'
                                                }`}
                                        >
                                            <p className="text-xs text-muted-foreground mb-1">GW {gw.event}</p>
                                            <p className="text-2xl font-black mb-1">{gw.points}</p>
                                            <div className="flex items-center justify-center gap-1 text-xs">
                                                {rankChange > 0 ? (
                                                    <TrendingUp className="w-3 h-3 text-green-500" />
                                                ) : rankChange < 0 ? (
                                                    <TrendingDown className="w-3 h-3 text-red-500" />
                                                ) : null}
                                                <span className={rankChange > 0 ? 'text-green-500' : rankChange < 0 ? 'text-red-500' : ''}>
                                                    {gw.overall_rank.toLocaleString()}
                                                </span>
                                            </div>
                                        </button>
                                    );
                                })}
                            </div>
                        </div>
                    </CardContent>
                </Card>

                {/* Selected GW Details */}
                {selectedGWData && (
                    <>
                        {/* GW Stats */}
                        <div className="grid md:grid-cols-4 gap-4">
                            <Card className="border-primary/20 bg-gradient-to-br from-primary/10 to-purple-500/10">
                                <CardContent className="p-6">
                                    <p className="text-sm text-muted-foreground mb-2">Points Scored</p>
                                    <p className="text-4xl font-black">{selectedGWData.points}</p>
                                    <p className="text-xs text-muted-foreground mt-1">
                                        Avg: {(history.current.reduce((sum: number, gw: any) => sum + gw.points, 0) / history.current.length).toFixed(1)}
                                    </p>
                                </CardContent>
                            </Card>

                            <Card className="border-primary/20">
                                <CardContent className="p-6">
                                    <p className="text-sm text-muted-foreground mb-2">Overall Rank</p>
                                    <p className="text-3xl font-black">{selectedGWData.overall_rank.toLocaleString()}</p>
                                    {prevGWData && (
                                        <div className="flex items-center gap-1 mt-1">
                                            {prevGWData.overall_rank - selectedGWData.overall_rank > 0 ? (
                                                <>
                                                    <TrendingUp className="w-4 h-4 text-green-500" />
                                                    <span className="text-xs text-green-500">+{(prevGWData.overall_rank - selectedGWData.overall_rank).toLocaleString()}</span>
                                                </>
                                            ) : (
                                                <>
                                                    <TrendingDown className="w-4 h-4 text-red-500" />
                                                    <span className="text-xs text-red-500">{(prevGWData.overall_rank - selectedGWData.overall_rank).toLocaleString()}</span>
                                                </>
                                            )}
                                        </div>
                                    )}
                                </CardContent>
                            </Card>

                            <Card className="border-primary/20">
                                <CardContent className="p-6">
                                    <p className="text-sm text-muted-foreground mb-2">Team Value</p>
                                    <p className="text-3xl font-black">£{(selectedGWData.value / 10).toFixed(1)}m</p>
                                    <p className="text-xs text-muted-foreground mt-1">Bank: £{(selectedGWData.bank / 10).toFixed(1)}m</p>
                                </CardContent>
                            </Card>

                            <Card className="border-primary/20">
                                <CardContent className="p-6">
                                    <p className="text-sm text-muted-foreground mb-2">Transfers</p>
                                    <p className="text-3xl font-black">{selectedGWData.event_transfers}</p>
                                    <p className="text-xs text-muted-foreground mt-1">
                                        Cost: {selectedGWData.event_transfers_cost} pts
                                    </p>
                                </CardContent>
                            </Card>
                        </div>

                        {/* Team Lineup */}
                        {picksData?.picks && (
                            <Card className="border-primary/20">
                                <CardHeader>
                                    <div className="flex items-center justify-between">
                                        <CardTitle>GW {selectedGW} - Team Lineup</CardTitle>
                                        <div className="flex gap-2">
                                            <Button
                                                variant="outline"
                                                size="sm"
                                                onClick={() => setSelectedGW(Math.max(1, selectedGW! - 1))}
                                                disabled={selectedGW === 1}
                                            >
                                                <ChevronLeft className="w-4 h-4" />
                                            </Button>
                                            <Button
                                                variant="outline"
                                                size="sm"
                                                onClick={() => setSelectedGW(Math.min(history.current.length, selectedGW! + 1))}
                                                disabled={selectedGW === history.current.length}
                                            >
                                                <ChevronRight className="w-4 h-4" />
                                            </Button>
                                        </div>
                                    </div>
                                </CardHeader>
                                <CardContent>
                                    <div className="space-y-4">
                                        {/* Starting XI */}
                                        <div>
                                            <h3 className="text-sm font-semibold mb-3 flex items-center gap-2">
                                                <Trophy className="w-4 h-4" />
                                                Starting XI
                                            </h3>
                                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                                                {picksData.picks
                                                    .filter((p: any) => p.position <= 11)
                                                    .map((pick: any) => (
                                                        <PlayerMiniCard
                                                            key={pick.element}
                                                            elementId={pick.element}
                                                            isCap={pick.is_captain}
                                                            isVC={pick.is_vice_captain}
                                                        />
                                                    ))
                                                }
                                            </div>
                                        </div>

                                        {/* Bench */}
                                        <div>
                                            <h3 className="text-sm font-semibold mb-3">Substitutes</h3>
                                            <div className="grid grid-cols-2 md:grid-cols-4 gap-3 opacity-75">
                                                {picksData.picks
                                                    .filter((p: any) => p.position > 11)
                                                    .map((pick: any) => (
                                                        <PlayerMiniCard
                                                            key={pick.element}
                                                            elementId={pick.element}
                                                        />
                                                    ))
                                                }
                                            </div>
                                        </div>

                                        {/* Additional Stats */}
                                        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 pt-4 border-t">
                                            <div className="text-center">
                                                <p className="text-xs text-muted-foreground">Points on Bench</p>
                                                <p className="text-2xl font-bold">{selectedGWData.points_on_bench}</p>
                                            </div>
                                            <div className="text-center">
                                                <p className="text-xs text-muted-foreground">Gameweek Rank</p>
                                                <p className="text-2xl font-bold">{selectedGWData.rank?.toLocaleString() || 'N/A'}</p>
                                            </div>
                                            <div className="text-center">
                                                <p className="text-xs text-muted-foreground">Total Points</p>
                                                <p className="text-2xl font-bold">{selectedGWData.total_points}</p>
                                            </div>
                                            <div className="text-center">
                                                <p className="text-xs text-muted-foreground">Chips Used</p>
                                                <p className="text-lg font-bold">{picksData.active_chip || 'None'}</p>
                                            </div>
                                        </div>
                                    </div>
                                </CardContent>
                            </Card>
                        )}
                    </>
                )}
            </div>
        </div>
    );
}
